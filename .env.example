# Server Configuration
HOST=0.0.0.0
PORT=8001

# Rate Limiting
RATE_LIMIT=10
RATE_WINDOW=60

# CORS Settings
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/server.log

# Session Configuration
SESSION_TIMEOUT=3600

# Ollama LLM Configuration
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# RAG Retrieval Configuration
# Paths (defaults to scripts/ directory relative to project root)
VECTOR_DIR=scripts/vector_db
DATA_DIR=scripts

# Retrieval tuning
RAG_PROP_K=8        # propositions to fetch from ChromaDB
RAG_CHUNK_K=10      # main chunks to fetch from ChromaDB
RAG_LEXICAL_K=12    # lexical fallback results
RAG_FINAL_K=8       # final merged context count
RAG_MAX_CHARS=7000  # max context characters sent to LLM
